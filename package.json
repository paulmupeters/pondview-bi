{
  "name": "pondview",
  "version": "0.2.0",
  "private": true,
  "license": "Apache-2.0",
  "bin": {
    "pondview": "./packages/cli/bin/pondview-dev.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/paulmupeters/pondview-bi"
  },
  "bugs": {
    "url": "https://github.com/paulmupeters/pondview-bi/issues"
  },
  "homepage": "https://github.com/paulmupeters/pondview-bi",
  "scripts": {
    "dev": "bun run --cwd packages/pondview-app dev",
    "build": "bun run --cwd packages/pondview-app build --outDir ../../dist --emptyOutDir",
    "preview": "bun run --cwd packages/pondview-app preview --outDir ../../dist",
    "typecheck": "bun run --cwd packages/pondview-app typecheck",
    "test": "bun run --cwd packages/pondview-app test",
    "deploy": "bun run build && npx wrangler deploy",
    "bridge": "bun run --cwd packages/cli src/cli.ts",
    "pondview": "bun run cli --",
    "bridge:build-ui": "bun run --cwd packages/pondview-app build --outDir ../cli/dist --emptyOutDir",
    "bridge:build-cli": "node -e \"require('node:fs').rmSync('packages/cli/lib',{recursive:true,force:true})\" && bun build packages/cli/src/cli.ts --target=node --format=esm --packages=external --outfile packages/cli/lib/cli.js",
    "bridge:typecheck": "bun run --cwd packages/cli typecheck",
    "bridge-protocol:build": "node -e \"require('node:fs').rmSync('packages/bridge-protocol/dist',{recursive:true,force:true})\" && bun build packages/bridge-protocol/src/index.ts --target=node --format=esm --packages=external --outfile packages/bridge-protocol/dist/index.js && tsc -p packages/bridge-protocol/tsconfig.build.json",
    "bridge-protocol:typecheck": "bun run --cwd packages/bridge-protocol typecheck",
    "cli:pack:dry-run": "bun run bridge-protocol:typecheck && bun run bridge:typecheck && bun pm pack --cwd packages/bridge-protocol --dry-run && bun pm pack --cwd packages/cli --dry-run",
    "docs:dev": "bun run --cwd packages/pondview-docs dev",
    "docs:build": "bun run --cwd packages/pondview-docs build",
    "docs:preview": "bun run --cwd packages/pondview-docs preview",
    "lint": "biome check . && bun run lint:deadcode",
    "lint:deadcode": "node scripts/check-dead-files.mjs",
    "check": "bun run typecheck && bun run bridge-protocol:typecheck && bun run bridge:typecheck && bun run lint && bun run test",
    "format": "biome format --write",
    "cli": "bun run --cwd packages/cli src/cli.ts",
    "cli:typecheck": "bun run bridge:typecheck",
    "cli:build": "bun run bridge:build-cli"
  },
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "^1.3.13",
    "@types/node": "^26.1.0",
    "typescript": "^7.0.2"
  },
  "trustedDependencies": [
    "@duckdb/node-api",
    "@duckdb/node-bindings",
    "@duckdb/node-bindings-darwin-arm64",
    "@duckdb/node-bindings-darwin-x64",
    "@duckdb/node-bindings-linux-x64",
    "@duckdb/node-bindings-linux-arm64",
    "@duckdb/node-bindings-win32-x64"
  ]
}
