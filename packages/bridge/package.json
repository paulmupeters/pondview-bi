{
  "name": "@pondview/cli",
  "version": "0.1.0",
  "private": false,
  "description": "Pondview CLI for running the local DuckDB bridge and bundled Pondview app.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/paulmupeters/pondview-bi#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/paulmupeters/pondview-bi",
    "directory": "packages/bridge"
  },
  "bugs": {
    "url": "https://github.com/paulmupeters/pondview-bi/issues"
  },
  "keywords": [
    "pondview",
    "duckdb",
    "bi",
    "analytics",
    "cli"
  ],
  "files": [
    "bin/pondview.mjs",
    "dist",
    "lib",
    "package.json",
    "README.md"
  ],
  "bin": {
    "pondview": "./bin/pondview.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run --cwd ../.. bridge:build-cli",
    "prepack": "bun run --cwd ../.. bridge:build-ui && bun run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@aws-sdk/client-s3": "^3.1056.0",
    "@duckdb/node-api": "^1.5.2-r.1",
    "@pondview/bridge-protocol": "^0.1.0",
    "ai": "6.0.204",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  }
}
