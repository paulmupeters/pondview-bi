{
  "name": "@pondview/bridge-protocol",
  "version": "0.2.0",
  "private": false,
  "description": "Shared Pondview bridge protocol schemas, types, and client.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/paulmupeters/pondview-bi#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/paulmupeters/pondview-bi",
    "directory": "packages/bridge-protocol"
  },
  "bugs": {
    "url": "https://github.com/paulmupeters/pondview-bi/issues"
  },
  "keywords": [
    "pondview",
    "duckdb",
    "bridge",
    "protocol"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run --cwd ../.. bridge-protocol:build",
    "prepack": "bun run build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^7.0.2"
  }
}
