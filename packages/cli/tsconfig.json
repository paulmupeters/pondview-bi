{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "types": ["bun", "node"],
    "baseUrl": ".",
    "paths": {
      "@pondview/bridge-protocol": ["../bridge-protocol/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
